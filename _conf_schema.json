{
  "ai_behavior": {
    "description": "AI 行为配置",
    "type": "object",
    "hint": "配置 AI 的功能权限",
    "items": {
      "allow_ai_help_deer": {
        "type": "bool",
        "description": "允许 AI 帮用户 🦌",
