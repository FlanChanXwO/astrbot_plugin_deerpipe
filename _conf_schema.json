        "default": false
      }
    }
  },
  "limits": {
    "description": "限制配置",
    "type": "object",
    "hint": "各种次数限制设置",
    "items": {
      "daily_retro_limit": {
        "type": "int",
        "description": "每日补🦌次数限制",
        "hint": "限制每个用户每天可以补打卡的次数。0 表示禁止补🦌，最大 31（一个月最多31天）。",
